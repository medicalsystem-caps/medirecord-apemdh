# =========================================================================
# MediRecord - Production API Credentials Example Configuration
# =========================================================================
# Copy this file to '.env.local' and replace the placeholders with your active keys.
# When these keys are supplied, the app automatically transitions from the local
# zero-config mock database/storage to secure cloud database and object storage.

# -------------------------------------------------------------------------
# 1. SUPABASE DATABASE CREDENTIALS (PostgreSQL & Audit Logs)
# -------------------------------------------------------------------------
# Instructions to get keys:
# a. Go to https://supabase.com and sign up for a free developer account.
# b. Click "New Project" and input database name, region, and master password.
# c. Once initialized, navigate to "Project Settings" -> "API" (left sidebar).
# d. Copy the "Project URL" and paste as NEXT_PUBLIC_SUPABASE_URL.
# e. Scroll down to "Project API Keys" and copy the hidden "service_role" key
#    (DO NOT share this key publicly; it bypasses RLS policies securely on the server).
# f. Copy the "anon" key and paste as NEXT_PUBLIC_SUPABASE_ANON_KEY.

NEXT_PUBLIC_SUPABASE_URL=https://xxnykiodnjnnhdybqzsn.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4bnlraW9kbmpubmhkeWJxenNuIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4NDAzNzAxNSwiZXhwIjoyMDk5NjEzMDE1fQ.u9ODaqy7pY9Ewmd_Bi4Ss-jXOTwQNyajRVY93A7ccRg
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh4bnlraW9kbmpubmhkeWJxenNuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQwMzcwMTUsImV4cCI6MjA5OTYxMzAxNX0.w_r7U4JjoZNyogwv_DeJiNEefJeRyxmmlK0TStSQcjQ

# -------------------------------------------------------------------------
# 2. CLOUDFLARE R2 OBJECT STORAGE (Birth/Death Supporting Attachments)
# -------------------------------------------------------------------------
# Instructions to get keys:
# a. Log in to the Cloudflare dashboard: https://dash.cloudflare.com/
# b. Go to "R2 Object Storage" in the sidebar and click "Create Bucket".
# c. Name your bucket (e.g. "medirecord-documents") and click create.
# d. To generate API keys: Navigate back to the "R2" home tab, click "Manage R2 API Tokens" on the right.
# e. Click "Create API Token", choose the "Object Read/Write" or "Admin" template, and click "Create Token".
# f. Copy the generated "Access Key ID" and "Secret Access Key" immediately.
# g. To get the S3 API Endpoint: Go to your bucket details -> "Settings" -> Copy the "S3 API Endpoint" 
#    (format: https://...r2.cloudflarestorage.com).
# h. To get Public Access URL: Under bucket settings, scroll to "Public Access" and click "Connect Domain" 
#    or click "Allow Access" to obtain a temporary cloudflare r2.dev subdomain.

CLOUDFLARE_R2_ACCESS_KEY_ID=37b8c3cae989006ee96fb4d550c4f7fe
CLOUDFLARE_R2_SECRET_ACCESS_KEY=13ea9be4af01d957d9d1afc55459a1f2a18eab50ad781ddc083d44ac6efdf51e
CLOUDFLARE_R2_ENDPOINT=https://40e258ef6cd5451292774efbede4d6b4.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET_NAME=medirecord-documents
CLOUDFLARE_R2_PUBLIC_URL=https://pub-6eae3c110aeb47668ba014d99e33533a.r2.dev
